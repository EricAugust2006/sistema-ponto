{
  "name": "sistema-ponto",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema de ponto para registramento de entrada/saida de funcionarios",
  "scripts": {
    "dev": "npm run services:up && npm run wait-for-postgres && npm run migration:up && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "npm run services:up && npm run wait-for-postgres && concurrently --names next,jest --hide next -k --success command-jest 'next dev' 'jest --runInBand'",
    "test:watch": "jest --watch --runInBand",
    "services:up": "docker compose -f _infra/compose.yaml up -d",
    "services:stop": "docker compose -f _infra/compose.yaml stop ",
    "services:down": "docker compose -f _infra/compose.yaml down",
    "migration:create": "node-pg-migrate --migrations-dir _infra/migrations create",
    "migration:up": "node-pg-migrate --migrations-dir _infra/migrations --envPath .env.development up",
    "migration:down": "node-pg-migrate --migrations-dir _infra/migrations --envPath .env.development down",
    "wait-for-postgres": "node _infra/scripts/wait-for-postgres.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "next": "16.2.9",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jest": "^30.4.2",
    "node-pg-migrate": "^8.0.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
